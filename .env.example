# Anthropic — required to run any agent. Build/test works without it.
ANTHROPIC_API_KEY=

# Model routing (overrides config defaults)
VB_MODEL_SCIENTIST=claude-sonnet-4-5
VB_MODEL_ORCHESTRATOR=claude-sonnet-4-5
VB_MODEL_SUPPORT=claude-haiku-4-5

# Optional data-source credentials / endpoints
OPEN_TARGETS_GRAPHQL=https://api.platform.opentargets.org/api/v4/graphql
CLINICALTRIALS_API=https://clinicaltrials.gov/api/v2
NCBI_API_KEY=
CBIOPORTAL_API=https://www.cbioportal.org/api

# Local dataset roots (see scripts/setup_data.py)
VB_DATA_DIR=./data
