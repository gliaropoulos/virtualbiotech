# ============================================================================
# Virtual Biotech environment configuration.
# Copy this file to `.env` (same directory) and fill in values.
# `.env` is gitignored; `src/virtual_biotech/config.py` loads it automatically.
# ============================================================================

# ---- REQUIRED to run agents -------------------------------------------------
# Your Anthropic API key. Build, import, and the full test suite work WITHOUT it;
# only live agent runs (the CSO + scientist agents) need it.
# Get one at https://console.anthropic.com/ -> API Keys.
ANTHROPIC_API_KEY=

# ---- Model routing (optional; these are the defaults) -----------------------
VB_MODEL_ORCHESTRATOR=claude-sonnet-4-5    # CSO orchestrator
VB_MODEL_SCIENTIST=claude-sonnet-4-5       # the 8 scientist agents
VB_MODEL_SUPPORT=claude-haiku-4-5          # Chief of Staff + Scientific Reviewer

# ---- Data-source API keys (all OPTIONAL) ------------------------------------
# The public MCP servers work with NO keys. These only RAISE RATE LIMITS for
# heavier usage; leave blank to use the anonymous tiers.
#
# NCBI E-utilities (PubMed): anonymous ~3 req/s, with key ~10 req/s.
#   Get one: https://www.ncbi.nlm.nih.gov/account/ -> Settings -> API Key Management
NCBI_API_KEY=
# OpenFDA (adverse events / drug labels): anonymous 240 req/min, with key 120k/day.
#   Get one: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# ---- Service endpoints (optional; override only if you mirror/pin a release) -
OPEN_TARGETS_GRAPHQL=https://api.platform.opentargets.org/api/v4/graphql
CLINICALTRIALS_API=https://clinicaltrials.gov/api/v2
CBIOPORTAL_API=https://www.cbioportal.org/api

# ---- Local data + single-cell (optional) ------------------------------------
# Where setup_data.py stores the data-gated datasets (Tabula Sapiens, Tahoe, DepMap,
# Open Targets cohort). Only needed for the single-cell case studies + full cohort run.
VB_DATA_DIR=./data
# Pin a specific CELLxGENE Census release (default: "stable").
VB_CENSUS_VERSION=stable
